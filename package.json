{
  "name": "openagent",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"apps/**/*.{ts,tsx,json}\"",
    "dev": "npm run dev --workspace apps/api & npm run dev --workspace apps/web",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "build": "npm run build --workspace apps/api && npm run build --workspace apps/web",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/**/*.{ts,tsx,json}": ["prettier --write"]
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0"
  }
}